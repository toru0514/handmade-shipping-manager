# Copy from .env.example and fill values for local development.

# === 共通: Google 認証 ===

# 方式1: サービスアカウント（推奨）
# GCPコンソールからダウンロードした service-account.json をbase64化して設定
# 例:
# node -e "const fs=require('fs');process.stdout.write(Buffer.from(fs.readFileSync('service-account.json','utf8')).toString('base64'))"
GOOGLE_SERVICE_ACCOUNT_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50IiwiY2xpZW50X2VtYWlsIjoieW91ci1zYUB5b3VyLXByb2plY3QuaWFtLmdzZXJ2aWNlYWNjb3VudC5jb20iLCJwcml2YXRlX2tleSI6Ii0tLS0tQkVHSU4gUFJJVkFURSBLRVktLS0tLVxuLi4uXG4tLS0tLUVORCBQUklWQVRFIEtFWS0tLS0tXG4ifQ==

# 方式2: OAuth2 リフレッシュトークン
# GOOGLE_SHEETS_ACCESS_TOKEN=
# GOOGLE_SHEETS_REFRESH_TOKEN=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# 方式3: 静的アクセストークン（テスト・一時利用向け）
# GOOGLE_SHEETS_ACCESS_TOKEN=

# === 発送管理 (shipping) ===
SHIPPING_SPREADSHEET_ID=your-spreadsheet-id
SHIPPING_ORDERS_SHEET_NAME=Orders
SHIPPING_LABELS_SHEET_NAME=ShippingLabels
SHIPPING_TEMPLATES_SHEET_NAME=Templates
# 商品名マッピング（A列: 元商品名 / B列: 表示名）
SHIPPING_PRODUCT_NAME_MAP_SHEET_NAME=ProductNameMap
# 発送方法ラベルマッピング（A列: shipping_methodコード / B列: 表示ラベル）
SHIPPING_METHOD_LABEL_SHEET_NAME=ShippingMethodLabelMap

# Gmail / Google OAuth（注文自動取得に必要）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GMAIL_ACCESS_TOKEN=
GMAIL_REFRESH_TOKEN=

# プラットフォーム認証
MINNE_EMAIL=
MINNE_PASSWORD=
CREEMA_EMAIL=
CREEMA_PASSWORD=

# Shipping providers
CLICKPOST_EMAIL=
CLICKPOST_PASSWORD=
# true の場合、クリックポストはブラウザ表示で手動ログインを待機します
CLICKPOST_MANUAL_LOGIN=false
# 手動ログイン待機時間（ミリ秒）
CLICKPOST_MANUAL_LOGIN_TIMEOUT_MS=300000
# true の場合、エラー時にブラウザを閉じずデバッグしやすくする
CLICKPOST_KEEP_BROWSER_OPEN_ON_ERROR=false
# true の場合、確認画面まで進んで停止（支払いは手動で行う）
CLICKPOST_DRY_RUN=true
YAMATO_MEMBER_ID=
YAMATO_PASSWORD=

# === 共通: Playwright ===
# Browserless（リモートブラウザ）
# 設定すると Playwright はローカル Chromium の代わりにリモートブラウザへ接続する。
# 未設定の場合はローカル Chromium を使用（従来動作）。
# Self-hosted: ws://localhost:3000
# Cloud:       wss://production-sfo.browserless.io?token=YOUR_TOKEN
# BROWSERLESS_WS_ENDPOINT=

# ブラウザをヘッドレスモードで実行（デフォルト: true）
PLAYWRIGHT_HEADLESS=true
# ブラウザ起動タイムアウト（ミリ秒）
PLAYWRIGHT_LAUNCH_TIMEOUT_MS=30000
# SSL証明書エラーを無視（プロキシ/VPN環境向け）
PLAYWRIGHT_IGNORE_HTTPS_ERRORS=false

# Optional: playwright module name (default: playwright)
PLAYWRIGHT_MODULE=playwright

# === 共通: Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# DB 同期用のサービスロールキー（サーバー専用、クライアントに公開しない）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === 共通: Slack 通知（省略可）===
# 注文取得完了・エラー時に Slack へ通知する。未設定の場合は通知しない。
SLACK_WEBHOOK_URL=

# === 出品管理 (pfauto) ===
PRODUCT_SPREADSHEET_ID=
PLAYWRIGHT_CREEMA_EMAIL=
PLAYWRIGHT_CREEMA_PASSWORD=
PLAYWRIGHT_MINNE_EMAIL=
PLAYWRIGHT_MINNE_PASSWORD=
PLAYWRIGHT_BASE_EMAIL=
PLAYWRIGHT_BASE_PASSWORD=
PLAYWRIGHT_IICHI_EMAIL=
PLAYWRIGHT_IICHI_PASSWORD=
PRODUCT_WORKSHEET_TITLE=共通
PRODUCT_COMMON_SHEET=共通
MICROCMS_API_KEY=
MICROCMS_SERVICE_DOMAIN=
